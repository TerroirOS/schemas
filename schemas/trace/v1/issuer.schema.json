{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.terroir.tech/trace/v1/issuer.schema.json",
  "title": "Trace Issuer",
  "description": "Issuer authority record.",
  "type": "object",
  "additionalProperties": false,
  "required": ["issuerId", "organizationName", "walletAddress", "roles", "trusted"],
  "properties": {
    "issuerId": { "type": "string", "minLength": 3 },
    "organizationName": { "type": "string", "minLength": 2 },
    "walletAddress": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "trusted": { "type": "boolean", "default": true }
  }
}
